{
  "expo": {
    "name": "DOGE Monitor",
    "slug": "doge-monitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.dogemonitor.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "dev.dogemonitor.app"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#f5a623"
        }
      ]
    ],
    "extra": {
      "reportUrl": "https://raw.githubusercontent.com/2kv9n8vc6y-png/doge-monitor/master/public/latest.json"
    }
  }
}
